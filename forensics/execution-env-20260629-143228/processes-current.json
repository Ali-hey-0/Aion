        "CommandLine":  "\"C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe\" -Command \"try { [Console]::OutputEncoding=[System.Text.Encoding]::UTF8 } catch {}\n$ErrorActionPreference=\u0027Stop\u0027\n$root = (Get-Location).Path\n$stamp = Get-Date -Format \u0027yyyyMMdd-HHmmss\u0027\n$out = Join-Path $root \\\"forensics\\execution-env-$stamp\\\"\nNew-Item -ItemType Directory -Force -Path $out | Out-Null\n\n$procPath = Join-Path $out \u0027processes-current.json\u0027\nGet-CimInstance Win32_Process |\n  Where-Object {\n    $_.Name -in @(\u0027aion.exe\u0027,\u0027Codex.exe\u0027,\u0027codex.exe\u0027,\u0027node.exe\u0027,\u0027cargo.exe\u0027,\u0027cmd.exe\u0027,\u0027powershell.exe\u0027,\u0027pwsh.exe\u0027) -or\n    ($_.CommandLine -match \u0027tauri|vite|Aion|CodexProfiles|OpenAI.Codex\u0027)\n  } |\n  Select-Object Name,ProcessId,ParentProcessId,CreationDate,ExecutablePath,CommandLine |\n  ConvertTo-Json -Depth 5 | Set-Content -LiteralPath $procPath -Encoding UTF8\n\n$agentEnvPath = Join-Path $out \u0027env-agent-current.json\u0027\nGet-ChildItem Env: |\n  Sort-Object Name |\n  Select-Object Name,Value |\n  ConvertTo-Json -Depth 3 | Set-Content -LiteralPath $agentEnvPath -Encoding UTF8\n\n$npmEnvPath = Join-Path $out \u0027env-npm-run-env.json\u0027\nnpm run env --silent |\n  ForEach-Object {\n    $idx = $_.IndexOf(\u0027=\u0027)\n    if ($idx -gt 0) {\n      [pscustomobject]@{ Name = $_.Substring(0,$idx); Value = $_.Substring($idx+1) }\n    }\n  } |\n  Sort-Object Name |\n  ConvertTo-Json -Depth 3 | Set-Content -LiteralPath $npmEnvPath -Encoding UTF8\n\n$binPath = Join-Path $out \u0027binaries.json\u0027\n$paths = @(\n  (Join-Path $root \u0027src-tauri\\target\\debug\\aion.exe\u0027),\n  \u0027C:\\Users\\WebVajhegan\\Desktop\\vs code\\Aion\\src-tauri\\target\\debug\\aion.exe\u0027,\n  (Join-Path $root \u0027src-tauri\\target\\release\\aion.exe\u0027),\n  \u0027C:\\Users\\WebVajhegan\\Desktop\\vs code\\Aion\\src-tauri\\target\\release\\aion.exe\u